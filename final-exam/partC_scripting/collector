#!/bin/bash
# Safe error-handled target file collection system

TARGET_DIR=${1:-"."}

if [ ! -d "$TARGET_DIR" ]; then
    echo "Error: Target directpath '$TARGET_DIR' does not exist." >&2
    exit 1
fi

echo "--- Starting Scan for target files inside: $TARGET_DIR ---"

# Loop through and handle reading logs smoothly
find "$TARGET_DIR" -type f -maxdepth 2 2>/dev/null | while read -r target_file; do
    # Only try to process files that are explicitly readable by the current user
    if [ -r "$target_file" ]; then
        echo "[READABLE]: $target_file ($(wc -l < "$target_file" 2>/dev/null) lines)"
    fi
done
