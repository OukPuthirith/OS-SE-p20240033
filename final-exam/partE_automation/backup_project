#!/bin/bash
# Backup project folder and enforce an absolute retention count limit

RETAIN_N=3
BACKUP_DIR="/home/$(whoami)/exam-backups"
SOURCE_DIR="/home/$(whoami)/final-exam"

# Ensure the backup directory exists
mkdir -p "$BACKUP_DIR"

# Step 1: Create the tarball named with a Unix timestamp
TIMESTAMP=$(date +%s)
BACKUP_FILE="$BACKUP_DIR/final-exam-$TIMESTAMP.tar.gz"

tar -czf "$BACKUP_FILE" -C "$SOURCE_DIR" . >/dev/null 2>&1
echo "[BACKUP] Created: final-exam-$TIMESTAMP.tar.gz"

# Step 2: Query existing files ordered by modification time (newest first)
# Use a newline-separated array to avoid issues with globbing
IFS=$'\n' CURRENT_BACKUPS=($(ls -t "$BACKUP_DIR"/final-exam-*.tar.gz 2>/dev/null))

# Step 3: Prune archives exceeding our RETAIN_N cap
if [ "${#CURRENT_BACKUPS[@]}" -gt "$RETAIN_N" ]; then
    echo "[PRUNE] Array limit exceeded. Removing oldest backups..."
    for ((i=$RETAIN_N; i<${#CURRENT_BACKUPS[@]}; i++)); do
        rm -f "${CURRENT_BACKUPS[$i]}"
        echo "[DELETED] Old backup: ${CURRENT_BACKUPS[$i]}"
    done
fi
