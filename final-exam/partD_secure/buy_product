#!/bin/bash
# PATCHED - Secured via exclusive advisory file locking

STOCK_FILE="stock.txt"
LOCK_FILE=".stock.lock"

(
    # Acquire exclusive lock on file descriptor 200
    flock -x 200

    # --- CRITICAL SECTION START ---
    CURRENT_STOCK=$(cat "$STOCK_FILE")

    # 🔴 LIVE CURVEBALL D HOOK GOES HERE 🔴
    # If your curveball dictates an order cap (e.g., CAP=5), you would add:
    # if [ "$REQUESTED_QTY" -gt "$CAP" ]; then echo "Rejected"; exit 1; fi

    if [ "$CURRENT_STOCK" -gt 0 ]; then
        sleep 0.1
        NEW_STOCK=$((CURRENT_STOCK - 1))
        echo "$NEW_STOCK" > "$STOCK_FILE"
        echo "[SUCCESS] Stock updated to $NEW_STOCK"
    else
        echo "[FAILED] Stock depleted"
    fi
    # --- CRITICAL SECTION END ---

) 200>"$LOCK_FILE"

